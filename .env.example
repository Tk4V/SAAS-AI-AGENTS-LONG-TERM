# Copy this file to .env and fill in real values. Never commit the resulting .env.

# Application
APP_ENV=local
APP_NAME=clyde-ai
APP_VERSION=0.1.0
LOG_LEVEL=INFO
DEBUG=false

# HTTP server
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Postgres connection used by the application.
# For local development against the docker-compose Postgres container, leave
# DB_HOST=localhost and use the matching user/password/database below.
# For dev and prod set DB_HOST to the AWS RDS endpoint and use the RDS creds.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clyde
DB_USER=clyde
DB_PASSWORD=clyde
# Set to "require" for AWS RDS, leave "disable" for local Docker Postgres.
DB_SSL=disable

# Bootstrap values for the local docker-compose Postgres container only.
# Not read by the app itself, just by the Postgres image when it first starts.
POSTGRES_DB=clyde
POSTGRES_USER=clyde
POSTGRES_PASSWORD=clyde

# JWT validation. The shared secret is issued by the Django DRF service,
# both services must use the same value with the HS256 algorithm.
JWT_SECRET=change-me-shared-with-django
JWT_ALGORITHM=HS256
JWT_AUDIENCE=clyde-ai

# Anthropic LLM
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL_OPUS=claude-opus-4-6
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5
ANTHROPIC_MAX_TOKENS=8192

# Voyage embeddings
VOYAGE_API_KEY=pa-xxxxxxxx
VOYAGE_MODEL=voyage-3-large
VOYAGE_DIMENSIONS=1024

# GitHub OAuth App
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
GITHUB_API_BASE=https://api.github.com

# OAuth flow settings.
# OAUTH_CALLBACK_BASE_URL must be the public origin where this FastAPI service
# is reachable, because GitHub will redirect the browser to a URL built from it.
# FRONTEND_REDIRECT_URL is where we send the user back after the OAuth dance.
OAUTH_STATE_TTL_SEC=600
OAUTH_CALLBACK_BASE_URL=http://localhost:8000
FRONTEND_REDIRECT_URL=http://localhost:3000/integrations

# LangSmith tracing. Get your API key at https://smith.langchain.com
# Set LANGCHAIN_TRACING_V2=true to enable tracing of every LangGraph pipeline step.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=clyde-ai
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Sandbox limits
SANDBOX_TIMEOUT_SEC=300
SANDBOX_MEMORY_LIMIT=2g
SANDBOX_CPU_LIMIT=1.0
SANDBOX_NETWORK=none

# Pipeline tuning
MAX_FIX_ATTEMPTS=3
MAX_REVIEW_ITERATIONS=3
MAX_QA_ITERATIONS=3

# Crypto for storing third-party MCP credentials at rest
FERNET_KEY=

# Optional observability
SENTRY_DSN=
PROMETHEUS_ENABLED=false
